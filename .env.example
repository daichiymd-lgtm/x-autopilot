# ============================================================
# X Autopilot 認証情報テンプレート
# 使い方:
#   ローカル実行 = このファイルを .env にコピーして実値を入れる
#   GitHub Actions = 値は .env に書かず、リポジトリ Secrets に登録する
#   ※ APIキーは絶対にチャット/コミットに貼らない（02-Mistakes 2026-06-10）
# ============================================================

# --- Claude (Anthropic) ---  分析・翻訳・スレ生成
ANTHROPIC_API_KEY=

# --- Grok (xAI) ---  海外/日本のリアルタイム収集（Live Search）
XAI_API_KEY=

# --- X (Twitter) API v2 ---  投稿（OAuth 1.0a User Context・書き込み権限）
# developer.x.com で App を作成し、@daichi631056 で Access Token を発行
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# --- Slack (任意) ---  実行ログ・エラー通知・バッファ予告
# 既存 Slack Bot Token があれば（なければ空でOK・通知スキップ）
SLACK_BOT_TOKEN=
SLACK_DM_CHANNEL=D09R3RM0ARY
